{
  "name": "@kava-now/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode production",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "tsx src/db/reset.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@kava-now/shared": "workspace:*",
    "better-auth": "^1.6.5",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "nodemailer": "^8.0.5",
    "postgres": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.3.0",
    "@hono/vite-dev-server": "^0.25.1",
    "@types/node": "^24.12.2",
    "@types/nodemailer": "^8.0.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.0",
    "vite": "^8.0.8"
  }
