{
  "name": "@kava-now/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build --mode production",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vp test --run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "tsx src/db/reset.ts",
    "email:dev": "email dev --dir src/emails --port 3001"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@kava-now/shared": "workspace:*",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.8",
    "@sentry/node": "^10.56.0",
    "better-auth": "^1.6.14",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.23",
    "nodemailer": "^8.0.10",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.12.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.11.1",
    "@hono/vite-dev-server": "^0.26.0",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.0",
    "drizzle-kit": "^0.31.10",
    "react-email": "^6.5.0",
    "tsx": "^4.22.4",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
