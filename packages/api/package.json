{
  "name": "@kava-now/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "vp build --mode production",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vp test --run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:reset": "tsx src/db/reset.ts",
    "email:dev": "email dev --dir src/emails --port 3001"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "@kava-now/shared": "workspace:*",
    "@react-email/render": "^2.0.10",
    "@sentry/node": "^10.64.0",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.28",
    "nodemailer": "^9.0.3",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-email": "^6.6.8",
    "resend": "^6.17.2",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.11.1",
    "@hono/vite-dev-server": "^0.26.0",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  }
}
