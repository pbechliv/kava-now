# =============================================================================
# KavaNow — Production Environment Variables
# Copy to .env and fill in real values before deploying.
# =============================================================================

# PostgreSQL
POSTGRES_USER=kavanow
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=kavanow

# Database URL (constructed from the above — used by the API)
DATABASE_URL=postgres://kavanow:CHANGE_ME_strong_random_password@postgres:5432/kavanow

# Application
NODE_ENV=production
PORT=3000
APP_URL=https://kavanow.gr
APP_DOMAIN=kavanow.gr

# Auth
SESSION_SECRET=CHANGE_ME_generate_a_64_char_random_string

# Email (production SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@kavanow.gr
SMTP_PASS=CHANGE_ME
SMTP_FROM=KavaNow <noreply@kavanow.gr>

# Caddy DNS challenge for wildcard TLS (if using Cloudflare)
CLOUDFLARE_API_TOKEN=CHANGE_ME

# Sentry error reporting (errors only — no tracing, no replay).
# DSNs are public ingest URLs, not secrets. Set both in production.
SENTRY_DSN_API=
SENTRY_DSN_WEB=
SENTRY_ENVIRONMENT=production
# Set to the deploy SHA at build time (CI: $GITHUB_SHA). Leave empty otherwise.
SENTRY_RELEASE=
