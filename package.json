{
  "name": "kava-now",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "pnpm --parallel --filter @kava-now/api --filter @kava-now/web dev",
    "dev:api": "pnpm --filter @kava-now/api dev",
    "dev:web": "pnpm --filter @kava-now/web dev",
    "build": "pnpm --filter @kava-now/shared --if-present build && pnpm --parallel --filter @kava-now/api --filter @kava-now/web build",
    "lint": "vp lint packages/",
    "fmt": "vp fmt --write packages/",
    "fmt:check": "vp fmt --check packages/",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "db:migrate": "pnpm --filter @kava-now/api db:migrate",
    "db:seed": "pnpm --filter @kava-now/api db:seed",
    "db:generate": "pnpm --filter @kava-now/api db:generate",
    "db:reset": "pnpm --filter @kava-now/api db:reset",
    "db:reseed": "pnpm db:reset && pnpm db:migrate && pnpm db:seed"
  },
  "devDependencies": {
    "typescript": "^7.0.2",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
}
