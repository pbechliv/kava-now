DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kavanow
# Optional: connect the running server as the NOSUPERUSER app role so RLS is
# enforced in dev too (it is bypassed when connecting as the postgres superuser).
# `pnpm db:migrate` provisions `kavanow_app` (dev password = the role name).
# Uncomment to opt in:
# APP_DATABASE_URL=postgresql://kavanow_app:kavanow_app@localhost:5432/kavanow
# Canonical origin of the running app. Used for absolute URLs in outbound email
# (invites, password resets, order notifications) and as better-auth's baseURL.
APP_ORIGIN=http://localhost:3200

# better-auth secret (session-cookie signing). Optional in dev (a fixed dev-only
# fallback is used); REQUIRED in production. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# SMTP (use Mailpit for local dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@kavanow.gr

# Resend (production transport). Leave empty in dev to fall back to Mailpit via SMTP_*.
RESEND_API_KEY=
RESEND_FROM=KavaNow <onboarding@resend.dev>

# API dev port — change if 3300 conflicts with another local service.
API_PORT=3300

# Superadmin credentials — only consumed by `pnpm db:seed` to create the platform-wide
# superadmin user. If unset, seed.ts falls back to the dev defaults baked into seeds/superadmin.ts.
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# Demo tenant — `pnpm db:seed` creates a demo kava (accessible at /k/demo) with mock customers/orders.
# The superadmin user owns the demo kava (use the in-app tenant switcher to enter it).
# Set SEED_DEMO=false to skip (recommended in production seed runs).
SEED_DEMO=true
DEMO_CUSTOMER_EMAIL=
DEMO_CUSTOMER_PASSWORD=

# Sentry error reporting. Leave SENTRY_DSN_* empty in dev to disable.
# Two projects: one `node` for the API, one `react` for the web SPA.
SENTRY_DSN_API=
SENTRY_DSN_WEB=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=

# Google OAuth — leave empty to disable "Continue with Google" in the UI.
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: ${APP_ORIGIN}/api/auth/callback/google
# The web SPA derives whether to render the Google button from the presence of these two values at build time.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
